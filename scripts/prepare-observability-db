#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

compose_file="infra/compose/compose.yaml"
docker compose -f "$compose_file" up -d observability-postgres >/dev/null
for _ in $(seq 1 60); do
  if docker compose -f "$compose_file" exec -T observability-postgres pg_isready -U nano_observability -d nano_observability >/dev/null 2>&1; then
    exit 0
  fi
  sleep 1
done
echo "observability-postgres did not become ready" >&2
exit 1
