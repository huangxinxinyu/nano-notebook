#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

export NANO_DATABASE_URL="${NANO_DATABASE_URL:-postgres://nano:nano@localhost:55432/nano?sslmode=disable}"
export NANO_CONTROL_PLANE_ADDR="${NANO_CONTROL_PLANE_ADDR:-:8080}"
export NANO_WORKER_ADDR="${NANO_WORKER_ADDR:-:8081}"
export NANO_COLLECTOR_ADDR="${NANO_COLLECTOR_ADDR:-:8082}"
export NANO_COLLECTOR_DATABASE_URL="${NANO_COLLECTOR_DATABASE_URL:-postgres://nano_observability:nano-observability@localhost:55433/nano_observability?sslmode=disable}"
export NANO_COLLECTOR_SERVICE_TOKEN="${NANO_COLLECTOR_SERVICE_TOKEN:-nano-local-collector-token}"
export NANO_COLLECTOR_QUERY_TOKEN="${NANO_COLLECTOR_QUERY_TOKEN:-nano-local-collector-query-token}"
export NANO_CHAT_MODEL="${NANO_CHAT_MODEL:-aliyun/qwen-flash}"
export NANO_BIFROST_URL="${NANO_BIFROST_URL:-http://127.0.0.1:56666}"

docker compose -f infra/compose/compose.yaml up -d
docker compose -f infra/compose/compose.yaml wait minio-init >/dev/null
for i in $(seq 1 60); do
  if docker compose -f infra/compose/compose.yaml exec -T postgres pg_isready -U nano -d nano >/dev/null 2>&1; then
    break
  fi
  sleep 1
done
scripts/prepare-observability-db
go run ./cmd/migrate

cleanup() {
  jobs -p | xargs -r kill 2>/dev/null || true
}
trap cleanup EXIT INT TERM

go run ./cmd/control-plane &
go run ./cmd/worker &
go run ./cmd/collector &
go run ./cmd/fetcher &
npm --prefix web run dev -- --host 127.0.0.1 &

wait
