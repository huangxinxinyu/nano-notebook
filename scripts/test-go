#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

export NANO_TEST_DATABASE_URL="${NANO_TEST_DATABASE_URL:-postgres://nano:nano@localhost:55432/nano_test?sslmode=disable}"
unformatted="$(gofmt -l cmd internal)"
if [ -n "$unformatted" ]; then
  echo "$unformatted"
  exit 1
fi
packages="$(go list ./... | grep -v '/web/node_modules/')"
go test -count=1 $packages
go vet $packages
go build ./cmd/control-plane ./cmd/worker ./cmd/migrate
